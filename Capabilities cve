#!/usr/bin/env python3

import subprocess
import json
from datetime import datetime
import os

# ==========================
# Capability Risk Mapping
# ==========================

CAP_RISK_MAP = {
    "cap_sys_admin": {"severity": "CRITICAL", "score": 9.5},
    "cap_setuid": {"severity": "CRITICAL", "score": 9.0},
    "cap_setgid": {"severity": "HIGH", "score": 8.0},
    "cap_dac_override": {"severity": "HIGH", "score": 7.5},
    "cap_net_admin": {"severity": "MEDIUM", "score": 6.5}
}

# ==========================
# Get capabilities from system
# ==========================

def get_capabilities():
    try:
        result = subprocess.run(
            ["getcap", "-r", "/"],
            capture_output=True,
            text=True,
            stderr=subprocess.DEVNULL
        )
        return result.stdout.strip().split("\n")
    except:
        return []

# ==========================
# Check if world writable
# ==========================

def is_world_writable(path):
    try:
        return bool(os.stat(path).st_mode & 0o002)
    except:
        return False

# ==========================
# Analyze capabilities
# ==========================

def analyze_capabilities(lines):
    findings = []

    for line in lines:
        if "=" not in line:
            continue

        path, caps = line.split("=", 1)
        caps = caps.lower()
        path = path.strip()

        for cap in CAP_RISK_MAP.keys():
            if cap in caps:

                risk_info = CAP_RISK_MAP[cap]
                world_writable = is_world_writable(path)

                score = risk_info["score"]
                if world_writable:
                    score += 0.5  # เพิ่มความเสี่ยงถ้าเขียนได้

                findings.append({
                    "binary": path,
                    "capability": cap,
                    "severity": risk_info["severity"],
                    "risk_score": round(score, 1),
                    "world_writable": world_writable,
                    "description": "Potential privilege escalation vector"
                })

    return findings

# ==========================
# MAIN
# ==========================

def main():
    print("=== Linux Capability Vulnerability Scanner (Advanced) ===\n")

    lines = get_capabilities()
    results = analyze_capabilities(lines)

    overall_risk = max([f["risk_score"] for f in results], default=0)

    report = {
        "timestamp": datetime.now().isoformat(),
        "total_findings": len(results),
        "overall_risk_score": overall_risk,
        "findings": results
    }

    print(json.dumps(report, indent=4))

    with open("capability_report.json", "w") as f:
        json.dump(report, f, indent=4)

    print("\nReport saved to capability_report.json\n")

if __name__ == "__main__":
    main()
