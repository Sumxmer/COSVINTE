# ══════════════════════════════════════════════════════════════════
#  COSVINTE — Clean Container (False Positive Test)
#  Ubuntu 24.04 fully patched, no intentional vulnerabilities
#  Clones directly from: https://github.com/Sumxmer/COSVINTE
# ══════════════════════════════════════════════════════════════════
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV TERM=xterm-256color

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip \
        git \
        cron \
        sudo \
        libcap2-bin \
        procps \
        lsb-release \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --break-system-packages reportlab packaging

# ── Clone COSVINTE from GitHub ─────────────────────────────────────
RUN git clone -b test https://github.com/Sumxmer/COSVINTE /opt/cosvinte

RUN mkdir -p /opt/cosvinte/reports && chmod 777 /opt/cosvinte/reports

# ── Harden: make sure nothing is misconfigured ────────────────────
RUN chmod 644 /etc/passwd \
    && chmod 1777 /tmp \
    && mkdir -p /etc/cron.d && chmod 755 /etc/cron.d

RUN useradd -m -s /bin/bash testuser && echo "testuser:testpass" | chpasswd

WORKDIR /opt/cosvinte
USER testuser

CMD ["python3", "cosvinte.py", "--all"]