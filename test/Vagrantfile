# -*- mode: ruby -*-
Vagrant.configure("2") do |config|

  # ── VM 1: VULNERABLE ──────────────────────────────────
  config.vm.define "vuln" do |v|
    v.vm.box      = "ubuntu/focal64"   # Ubuntu 20.04
    v.vm.hostname = "cosvinte-vuln"
    v.vm.provider "virtualbox" do |vb|
      vb.memory = 2048
      vb.cpus   = 2
      vb.name   = "COSVINTE-Vulnerable"
    end
    v.vm.provision "shell", inline: <<-SHELL
      echo "[*] Installing old vulnerable kernel 5.8.0..."
      apt-get update -qq
      apt-get install -y linux-image-5.8.0-63-generic linux-headers-5.8.0-63-generic
      # Set as default boot kernel
      sed -i 's/GRUB_DEFAULT=0/GRUB_DEFAULT="Advanced options for Ubuntu>Ubuntu, with Linux 5.8.0-63-generic"/' /etc/default/grub
      update-grub

      # Simulate vulnerable conditions for other scanners
      chmod 777 /var/log                  # writable path
      chmod 777 /tmp
      apt-get install -y git python3 python3-pip
      pip3 install packaging requests
      git clone -b test https://github.com/Sumxmer/COSVINTE/ /home/vagrant/COSVINTE
      chown -R vagrant:vagrant /home/vagrant/COSVINTE

      echo "[*] Done. Reboot required for kernel 5.8.0 to activate."
    SHELL
  end

  # ── VM 2: PATCHED ──────────────────────────────────────
  config.vm.define "patched" do |v|
    v.vm.box      = "ubuntu/jammy64"   # Ubuntu 22.04 LTS
    v.vm.hostname = "cosvinte-patched"
    v.vm.provider "virtualbox" do |vb|
      vb.memory = 2048
      vb.cpus   = 2
      vb.name   = "COSVINTE-Patched"
    end
    v.vm.provision "shell", inline: <<-SHELL
      echo "[*] Updating to latest patched kernel..."
      apt-get update -qq && apt-get upgrade -y
      apt-get install -y git python3 python3-pip
      pip3 install packaging requests
      git clone -b test https://github.com/Sumxmer/COSVINTE/ /home/vagrant/COSVINTE
      chown -R vagrant:vagrant /home/vagrant/COSVINTE
      echo "[*] Done."
    SHELL
  end

end